---
import GitHub from "./icons/Github.astro";
import Spring from "./icons/Spring.astro";
import Link from "./icons/Link.astro";
import LinkButton from "./LinkButton.astro";
import ProjectPill from "./ProjectPill.astro";
import Java from "./icons/Java.astro";
import React from "./icons/React.astro";

const PROJECTS = [
  {
    title: "InventoryMotor",
    description:
      "Sitio web para llevar la gestion del inventario en una empresa que vende repuestos para motos, se puede llevar un control de las existencias, las ventas y los pedidos.",
    link: "https://jorgedibarra.github.io/inventario-front/",
    github: "https://github.com/jorgedibarra/Inventory-Motor",
    image: "/projects/inventoryMotor.webp",
    tech: [
      { name: "Java", icon: Java },
      { name: "Spring Boot", icon: Spring },
      { name: "React", icon: React },
    ],
  },
  {
    title: "Simulación de nivel de un tanque",
    description:
      "Simulación de un sistema de control de nivel de un tanque, donde se aplico la libreria JavaFX y el patron arquitectonico MVC.",
    link: "https://youtu.be/6KHwnyPfRVggi",
    github: "https://github.com/jorgedibarra/SimulacionTanque",
    image: "/projects/simulacion.webp",
    tech: [
      { name: "Java", icon: Java },
      { name: "JavaFX", icon: Java },
    ],
  },
];
---

<div class="flex flex-col space-y-16">
  {
    PROJECTS.map(({ title, description, image, github, link, tech }) => (
      <article class="flex flex-col space-y-8 group md:flex-row md:space-x-8 md:space-y-0">
        <div class="w-full md:w-1/2">
          <div class="relative flex flex-col items-center col-span-6 row-span-5 gap-8 transition duration-500 ease-in-out transform shadow-xl overflow-clip rounded-xl sm:rounded-xl md:group-hover:-translate-y-1 md:group-hover:shadow-2xl lg:border lg:border-gray-800 lg:hover:border-gray-700 lg:hover:bg-gray-800/50">
            <img
              class="object-cover object-top w-full h-auto object-contain transition duration-500 sm:h-full md:scale-110 md:group-hover:scale-105"
              loading="lazy"
              src={image}
              alt={`Captura de pantalla del proyecto ${image}`}
            />
          </div>
        </div>
        <div class="w-full md:w-1/2 md:max-w-lg flex flex-col gap-4">
          <h3 class="text-2xl font-semibold text-green-300">{title}</h3>

          <ul class="flex flex-wrap gap-3 sm:gap-4">
            {tech.map(({ name, icon: Icon }) => (
              <ProjectPill>
                <Icon class="size-4 md:size-4" />
                <li>{name}</li>
              </ProjectPill>
            ))}
          </ul>
          <p class="text-gray-200">{description}</p>
          <footer class="flex gap-2 sm:gap-4 py-2 w-full md:w-auto order-3">
            {github && (
              <LinkButton href={github}>
                <GitHub class="size-5" />
                Codigo
              </LinkButton>
            )}
            {link && (
              <LinkButton href={link}>
                <Link class="size-4" />
                Vista previa
              </LinkButton>
            )}
          </footer>
        </div>
      </article>
    ))
  }
</div>
