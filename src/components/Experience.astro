---
import ExperienceItem from "../components/ExperienceItem.astro";

const EXPERIENCE = [
  {
    date: "Septiembre 2025 - Marzo 2026",
    title: "Practicante de Ingenieria de Sistemas - CENS (Grupo EPM)",
    description:
      "Participé en el desarrollo de la primera versión del sistema SITMEC (Sistema de Trazabilidad en Metrología, Ensayos y Calidad), apoyando el ciclo completo de desarrollo de software: levantamiento y análisis de requerimientos, desarrollo de la aplicación y pruebas funcionales internas y con usuarios finales. También contribuí al despliegue en ambiente QA, gestioné tareas con Azure DevOps y elaboré documentación técnica y manuales de usuario, trabajando bajo la metodología Scrum.",
  },
];
---

<ol class="relative border-s border-gray-200 ml-3">
  {
    EXPERIENCE.map((experiencie) => (
      <li class="mb-10 ms-4">
        <ExperienceItem {...experiencie} />
      </li>
    ))
  }
</ol>
